# Python bytecode
__pycache__/
*.pyc

# Virtual environment
venv/
env/

# Local database
db.sqlite3

# Media files (user-uploaded files)
media/

# Static files (generated by collectstatic, if not committed)
static/ # If you're using a separate static storage or not committing static files

# Environment variables and sensitive settings
.env
local_settings.py # Or any other file containing local/sensitive settings

# Log files
*.log

# IDE-specific files (e.g., PyCharm)
.idea/
.vscode/

# Operating system files
.DS_Store
Thumbs.db

# Test coverage reports
.coverage*

# Build artifacts
target/